{
  "name": "kleptowriter",
  "version": "0.4.2",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter '@kleptowriter/*' build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "version:check": "bun run packages/kleptowriter-core/src/versioning/cli.ts"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/turndown": "5.0.6",
    "typescript": "^5.9.2"
  }
}

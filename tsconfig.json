{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["bun"],
    "baseUrl": ".",
    "paths": {
      "@kleptowriter/kleptowriter-core": ["packages/kleptowriter-core/src/index.ts"],
      "@kleptowriter/kleptowriter-core/*": ["packages/kleptowriter-core/src/*"]
    }
  },
  "include": ["packages/**/*.ts", "examples/**/*.ts"],
  "exclude": ["node_modules", "dist", "coverage"]
}
